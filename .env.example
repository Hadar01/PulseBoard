# ============================================================
# PulseBoard-RAG — Environment Configuration Template
# Copy this file to .env and fill in your values.
# Or run:  pulseboard-config  for an interactive setup wizard.
# ============================================================

# ── LLM (set at least one) ───────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...

# Model names (defaults shown — change to use a different model)
CLAUDE_MODEL=claude-sonnet-4-6
GEMINI_MODEL=gemini-2.0-flash

# ── Demo Mode ────────────────────────────────────────────────
# true  = use mock data, no API keys required (great for demos)
# false = use real Slack / GitHub / Notion / LLM APIs
DEMO_MODE=true

# ── Slack Integration ────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-...
SLACK_CHANNELS=client-pharma,client-insurance,general

# ── GitHub Integration ───────────────────────────────────────
GITHUB_TOKEN=ghp_...
GITHUB_REPOS=org/repo1,org/repo2

# ── Notion Integration ───────────────────────────────────────
NOTION_TOKEN=secret_...
NOTION_DATABASE_ID=your-database-id-here

# ── Heartbeat Scheduler ──────────────────────────────────────
DIGEST_INTERVAL_MINUTES=30
MAX_DIGEST_HISTORY=48        # how many digests to keep in memory

# ── RAG Settings ─────────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_db
CHUNK_SECONDS=120            # transcript chunk window in seconds
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIM=384            # must match EMBEDDING_MODEL output dim

# ── API Security ─────────────────────────────────────────────
# Comma-separated list of allowed browser origins.
# Use "*" only in development — always restrict in production.
CORS_ORIGINS=http://localhost:8501

# ── HTTP Timeouts ────────────────────────────────────────────
API_REQUEST_TIMEOUT=20       # seconds for Slack / GitHub / Notion calls
LLM_TIMEOUT=60               # seconds for LLM API calls

# ── Dashboard ────────────────────────────────────────────────
API_BASE_URL=http://localhost:8000

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=INFO
